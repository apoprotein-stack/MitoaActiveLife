        <svg class="silhouette-decor top-20 -left-20 w-[600px] h-auto float-anim" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M40,160 Q60,140 80,160 T120,160 M30,140 Q50,120 70,140 T110,140 M50,110 L50,180 M20,130 Q50,100 80,130 M100,100 Q130,70 160,100" stroke="#9E7A3D" stroke-width="0.5" fill="none"/>
