        </div>
        <div class="hidden md:flex space-x-10 text-[13px] tracking-[0.15em] font-medium items-center text-slate-800">
            <a href="#vision" class="hover:text-amber-800 transition" data-t="nav_vision">世界觀</a>
            <a href="#science" class="hover:text-amber-800 transition" data-t="nav_science">科學論證</a>
            <a href="#programs" class="hover:text-amber-800 transition" data-t="nav_programs">管理計畫</a>
            <div class="flex space-x-4 ml-6 border-l border-slate-300 pl-6 text-slate-500">
                <button onclick="changeLang('zh')" id="btn-zh" class="lang-active hover:text-amber-700 transition">繁</button>
                <button onclick="changeLang('jp')" id="btn-jp" class="hover:text-amber-700 transition">日</button>
            </div>
        </div>
    </nav>

    <!-- 第一屏 (Hero Section) -->
