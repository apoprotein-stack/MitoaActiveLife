                </div>
            </div>
        </div>
    </section>

    <!-- 管理計畫 (Programs Section) -->
    <section id="programs" class="relative py-36 px-10 bg-[#FAF9F6] overflow-hidden">
        <!-- 剪影背景: 竹林感線條 (Silhouette 3) -->
        <div class="silhouette-decor top-0 left-10 h-full w-[1px] bg-amber-800/20"></div>
        <div class="silhouette-decor top-0 left-14 h-full w-[1px] bg-amber-800/10"></div>
        <div class="silhouette-decor top-0 left-24 h-full w-[1px] bg-amber-800/5"></div>

        <div class="max-w-6xl mx-auto relative z-10">
            <div class="text-center mb-24 reveal">
                <h3 class="text-4xl serif mb-6 text-slate-900" data-t="plan_annual_title_main">生命管理計畫</h3>
                <div class="w-16 h-[2px] bg-amber-800 mx-auto"></div>
            </div>

            <div class="grid md:grid-cols-2 gap-10">
                <!-- 年計畫 -->
                <div class="bg-white p-16 border border-slate-100 soft-shadow reveal flex flex-col justify-between hover:border-amber-800/30 transition duration-500 group">
                    <div>
                        <div class="flex justify-between items-start mb-12">
                            <div>
                                <h4 class="text-3xl serif mb-3 text-slate-900" data-t="plan_annual_title">極緻生命計畫</h4>
                                <p class="text-[11px] text-amber-800 font-bold tracking-[0.2em] uppercase">Annual Longevity</p>
                            </div>
                        </div>
                        <ul class="space-y-5 text-[15px] text-slate-700 font-normal mb-12">
                            <li class="flex items-start"><span class="mr-3 text-amber-800">◆</span> 全系列高效能配方 (12月份)</li>
                            <li class="flex items-start"><span class="mr-3 text-amber-800">◆</span> 兩次端粒生物時鐘精準檢測</li>
                            <li class="flex items-start"><span class="mr-3 text-amber-800">◆</span> 專屬健康管理師季度追蹤</li>
                        </ul>
                    </div>
                    <div>
                        <div class="text-3xl font-light text-slate-900 mb-10 tracking-tight">NT$ 29,800</div>
                        <button class="w-full py-5 bg-slate-900 text-white text-xs tracking-[0.2em] font-bold uppercase hover:bg-amber-800 transition duration-500" data-t="btn_annual">立即預約年度管理</button>
                    </div>
                </div>

                <!-- 季度計畫 -->
                <div class="bg-white p-16 border border-slate-100 soft-shadow reveal flex flex-col justify-between hover:border-amber-800/30 transition duration-500 group">
                    <div>
                        <div class="flex justify-between items-start mb-12">
                            <div>
                                <h4 class="text-3xl serif mb-3 text-slate-900" data-t="plan_90_title">平衡啟動計畫</h4>
                                <p class="text-[11px] text-amber-800 font-bold tracking-[0.2em] uppercase">90-Day Reset</p>
                            </div>
                        </div>
                        <ul class="space-y-5 text-[15px] text-slate-700 font-normal mb-12">
                            <li class="flex items-start"><span class="mr-3 text-amber-800">◆</span> Mito Core 能量基石 (3月份)</li>
                            <li class="flex items-start"><span class="mr-3 text-amber-800">◆</span> 細胞能量修復外用精華</li>
                            <li class="flex items-start"><span class="mr-3 text-amber-800">◆</span> 初階細胞老化技術指南</li>
                        </ul>
                    </div>
                    <div>
                        <div class="text-3xl font-light text-slate-900 mb-10 tracking-tight">NT$ 8,800</div>
                        <button class="w-full py-5 btn-outline text-xs tracking-[0.2em] font-bold uppercase" data-t="btn_90">開始季度重塑</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-24 px-10 bg-slate-900 text-white relative overflow-hidden">
        <!-- 頁尾剪影: 富士山感山影 -->
        <div class="absolute bottom-0 left-0 w-full h-32 bg-amber-800/10 clip-mountain opacity-20"></div>
        
        <div class="max-w-6xl mx-auto flex flex-col items-center relative z-10">
            <div class="text-2xl font-light tracking-[0.3em] uppercase mb-12">Mito<span class="font-bold text-amber-500">ActiveLife</span></div>
            <div class="text-xs text-slate-400 max-w-2xl text-center leading-loose mb-12" data-t="footer_legal">
                本品牌所有敘事基於現有生物科學研究框架。我們尊重科學證據的邊界，產品旨在支持健康管理，不具備醫療效能，無法替代醫師專業診斷。
            </div>
            <div class="text-[10px] tracking-widest text-slate-500 uppercase">
                &copy; 2026 MitoActiveLife. Scientific Excellence.
            </div>
        </div>
    </footer>

    <script>
        const i18n = {
            zh: {
                nav_vision: "世界觀",
                nav_science: "科學論證",
                nav_programs: "管理計畫",
                hero_vertical: "細胞の時間を、美しく。",
                hero_title: "老化不是數字，<br>是細胞呈現的<span class='text-amber-800 font-semibold'>風景</span>。",
                hero_desc: "當細胞能量與修復機制處於和諧狀態，時間便不再是威脅。<br>我們致力於讓每一顆細胞，都擁有抵禦時間的力量。",
                science_title: "源自 2009 年的<br>科學啟示",
                science_desc_1: "諾貝爾獎揭示了「端粒與端粒酶」的機制，正式開啟了人類與老化對話的新篇章。這不僅是生物學的突破，更是掌握生命長度的密碼。",
                science_desc_2: "MitoActiveLife 站在這份遺產之上，將目光投向更深處的連結：端粒的修復需要龐大能量，而能量的源頭就在「粒線體」。",
                science_quote: "「端粒是時鐘，<br>粒線體是電池。」",
                science_framework: "端粒防護 ‧ 粒線體供能 ‧ 腸道微生態",
                plan_annual_title_main: "生命管理計畫",
                plan_annual_title: "極緻生命計畫",
                plan_90_title: "平衡啟動計畫",
                btn_annual: "立即預約年度管理",
                btn_90: "開始季度重塑",
                footer_legal: "本品牌所有敘事基於現有生物科學研究框架。我們尊重科學證據的邊界，產品旨在支持健康管理，不具備醫療效能，無法替代醫師專業診斷。"
            },
            jp: {
                nav_vision: "世界観",
                nav_science: "科学的根拠",
                nav_programs: "プログラム",
                hero_vertical: "細胞の時間を、美しく。",
                hero_title: "老化は数字ではなく、<br>細胞が描く<span class='text-amber-800 font-semibold'>風景</span>である。",
                hero_desc: "細胞のエネルギーと修復機能が調和した時、時間はもはや脅威ではありません。<br>私たちは、すべての細胞に時の流れに抗う力を与えます。",
                science_title: "2009年のノーベル賞に<br>基づく科学的示唆",
                science_desc_1: "ノーベル生理学・医学賞は「テロメアとテロメラーゼ」の仕組みを解明し、老化管理の新たな扉を開きました。これは単なる発見ではなく、寿命の暗号を解く鍵です。",
                science_desc_2: "MitoActiveLifeは、テロメア保護に不可欠な能量の源泉である「ミトコンドリア」に着目し、その機能を最適化します。",
                science_quote: "「テロメアは時計であり、<br>ミトコンドリアは電池である。」",
                science_framework: "テロメア保護 ‧ ミトコンドリア管理 ‧ 腸内フローラ",
                plan_annual_title_main: "ライフマネジメント",
                plan_annual_title: "究極の生命プログラム",
                plan_90_title: "バランス起動プログラム",
                btn_annual: "年間管理を予約する",
                btn_90: "クォータープランを開始",
                footer_legal: "当ブランドの叙述は、現在の生物科学研究に基づいています。科学的根拠を尊重し、製品は健康維持を目的としており、医療行為に代わるものではありません。"
            }
        };

        function changeLang(lang) {
            document.querySelectorAll('[data-t]').forEach(el => {
                const key = el.getAttribute('data-t');
                if (i18n[lang][key]) {
                    el.innerHTML = i18n[lang][key];
                }
            });
            document.getElementById('btn-zh').classList.toggle('lang-active', lang === 'zh');
            document.getElementById('btn-jp').classList.toggle('lang-active', lang === 'jp');
            document.documentElement.lang = lang === 'zh' ? 'zh-Hant' : 'ja';
        }

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        window.addEventListener('scroll', () => {
            const nav = document.getElementById('main-nav');
            if (window.scrollY > 20) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
            
            // 輕微的視差效果
            const scrolled = window.pageYOffset;
            document.querySelectorAll('.silhouette-decor').forEach(el => {
                const speed = 0.05;
                el.style.transform = `translateY(${scrolled * speed}px)`;
            });
        });
    </script>
</body>
</html>
